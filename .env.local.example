# =============================================
# Fazumi — Web App Environment Variables
# Copy to .env.local for local development.
# =============================================
# Note: Do not set NODE_ENV in .env files. Next.js manages NODE_ENV automatically.

# Core
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin dashboard
# Admin login stays disabled unless both credentials AND the signing key are set.
# ADMIN_SIGNING_KEY must be a random secret (min 32 characters recommended). Generate with:
#   Node.js: require('crypto').randomBytes(32).toString('hex')
#   PowerShell: -join ((48..57) + (65..90) + (97..122) | Get-Random -Count 32 | ForEach-Object {[char]$_})
#
# Production: set ADMIN_USERNAME, ADMIN_PASSWORD, and ADMIN_SIGNING_KEY in your hosting env.
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SIGNING_KEY=
#
# Local dev convenience (NODE_ENV != production only — ignored in production builds):
# DEV_ADMIN_* vars are used as a fallback when the ADMIN_* vars above are empty.
# Never set these in production. Production must use the ADMIN_* vars above.
DEV_ADMIN_USERNAME=admin
DEV_ADMIN_PASSWORD=admin
# DEV_ADMIN_SIGNING_KEY=local-dev-signing-key-at-least-32-chars-long

# OAuth providers — set to "true" only after enabling in Supabase Auth → Providers
# Supabase dashboard: Authentication → Providers → Google / Apple
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false
NEXT_PUBLIC_AUTH_APPLE_ENABLED=false

# Lemon Squeezy
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=
# Required for pricing/checkout CTAs. Use the UUID from the Lemon Squeezy checkout buy URL.
# Format: https://fazumi.lemonsqueezy.com/checkout/buy/<uuid>
NEXT_PUBLIC_LS_MONTHLY_VARIANT=<uuid-from-ls-checkout-url>
NEXT_PUBLIC_LS_ANNUAL_VARIANT=<uuid-from-ls-checkout-url>
NEXT_PUBLIC_LS_FOUNDER_VARIANT=<uuid-from-ls-checkout-url>
# Set to "1" to enable live checkout. Leave unset while payment provider approval is pending.
PAYMENTS_ENABLED=

# Web Push Notifications (morning digest)
# Generate keys: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@fazumi.app

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_POSTHOG_SESSION_RECORDING=true

# Cron security for morning digest
CRON_SECRET=
