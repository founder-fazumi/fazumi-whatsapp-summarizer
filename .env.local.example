# =============================================
# Fazumi — Web App Environment Variables
# Copy to .env.local for local development.
# =============================================
# Note: Do not set NODE_ENV in .env files. Next.js manages NODE_ENV automatically.

# Core
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin dashboard
# Admin login stays disabled unless both credentials are set explicitly.
# ADMIN_SIGNING_KEY must be a random secret (min 32 characters recommended). Generate with:
#   Node.js: crypto.randomBytes(32).toString('hex')
#   PowerShell: -join ((48..57) + (65..90) + (97..122) | Get-Random -Count 32 | ForEach-Object {[char]$_})
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SIGNING_KEY=

# OAuth providers — set to "true" only after enabling in Supabase Auth → Providers
# Supabase dashboard: Authentication → Providers → Google / Apple
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false
NEXT_PUBLIC_AUTH_APPLE_ENABLED=false

# Lemon Squeezy (deprecated — kept until Paddle integration is complete)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=
NEXT_PUBLIC_LS_MONTHLY_VARIANT=
NEXT_PUBLIC_LS_ANNUAL_VARIANT=
NEXT_PUBLIC_LS_FOUNDER_VARIANT=

# Paddle (active payment provider)
# Server-only — never expose these to the client or commit them.
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
# Public price IDs — find in Paddle dashboard → Catalog → Products → open plan → Prices → copy ID.
# Format: pri_<alphanumeric>  e.g. pri_01abc123def456
NEXT_PUBLIC_PADDLE_MONTHLY_PRICE_ID=
NEXT_PUBLIC_PADDLE_ANNUAL_PRICE_ID=
NEXT_PUBLIC_PADDLE_FOUNDER_PRICE_ID=
# Set to "sandbox" for testing, "production" when going live.
NEXT_PUBLIC_PADDLE_ENVIRONMENT=sandbox
# Set to "1" to enable live checkout. Leave unset until Paddle integration is fully tested.
PAYMENTS_ENABLED=

# Web Push Notifications (morning digest)
# Generate keys: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@fazumi.app

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_POSTHOG_SESSION_RECORDING=true

# Cron security for morning digest
CRON_SECRET=
