# =============================================
# Fazumi — Web App Environment Variables
# Copy to .env.local for local development.
# =============================================
# Note: Do not set NODE_ENV in .env files. Next.js manages NODE_ENV automatically.

# Core
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin dashboard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Lemon Squeezy
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=
# Required for pricing/checkout CTAs. Use the exact Lemon Squeezy variant IDs.
NEXT_PUBLIC_LS_MONTHLY_VARIANT=<your_variant_id>
NEXT_PUBLIC_LS_ANNUAL_VARIANT=<your_variant_id>
NEXT_PUBLIC_LS_FOUNDER_VARIANT=<your_variant_id>

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_POSTHOG_SESSION_RECORDING=true

# Web push
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@fazumi.app

# Cron security for morning digest
CRON_SECRET=
